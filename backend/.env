# ── Sarvam AI ────────────────────────────────────────────────────────────────
SARVAM_API_KEY=
SARVAM_BASE_URL=https://api.sarvam.ai

# ── Data paths ───────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
FAQ_PDF_PATH=data/faq.pdf
PRODUCTS_JSON_PATH=data/products.json

# ── App tuning ────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=3600
MAX_RAG_RESULTS=5
LOG_LEVEL=INFO

# ── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Dev: your-tunnel.trycloudflare.com   Prod: your-app.onrender.com
PUBLIC_HOST=

# ── GitHub MCP ───────────────────────────────────────────────────────────────
GITHUB_PERSONAL_ACCESS_TOKEN=